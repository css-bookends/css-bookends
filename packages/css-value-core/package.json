{
  "name": "@css-bookends/css-value-core",
  "version": "0.1.0",
  "description": "The shared css-value validate/render engine: the table-driven single-value helper factory plus the multi-part helpers, layered on the css-calipers scalar primitives. The per-property books import this engine the way every book imports self-publish.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/css-bookends/css-bookends.git",
    "directory": "packages/css-value-core"
  },
  "bugs": {
    "url": "https://github.com/css-bookends/css-bookends/issues"
  },
  "homepage": "https://github.com/css-bookends/css-bookends#readme",
  "author": "slafleche",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "css",
    "bookends",
    "css-values",
    "csstype",
    "typed-css"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "type": "commonjs",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "csstype": "^3.2.3"
  },
  "peerDependencies": {
    "@css-bookends/css-calipers": "workspace:*"
  },
  "devDependencies": {
    "@css-bookends/css-calipers": "workspace:*",
    "@css-bookends/eslint-config": "workspace:*",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "tsd": "^0.33.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json && node scripts/emit-esm-package.mts",
    "test": "npm run build && npm run test:unit && npm run test:types && npm run test:tsc && npm run lint",
    "test:unit": "vitest run tests/runtime",
    "test:types": "tsd --files tests/types/**/*.test-d.ts",
    "test:tsc": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0"
  }
}
