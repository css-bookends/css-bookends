{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "types": [
      "vitest",
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@css-bookends/css-calipers": [
        "src/index.ts"
      ],
      "@css-bookends/css-calipers/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "tests"
  ],
  "exclude": [
    "tests/types",
    "tests/nodenext",
    "tests/runtime/**/*.cjs.test.ts",
    "tests/runtime/**/*.esm.test.ts",
    "tests/runtime/api-surface/**"
  ]
}
