{
  "name": "@css-bookends/css-bookends",
  "private": true,
  "version": "0.0.0",
  "description": "CSS-Bookends monorepo: typed, opt-in CSS helper books.",
  "license": "MIT",
  "author": "slafleche",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/css-bookends/css-bookends.git"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:browser": "playwright test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r run test:tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bash scripts/release-all.sh",
    "release:npm-only": "pnpm -r build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-multiline-arrays": "^4.1.8"
  }
}
