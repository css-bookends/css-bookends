{
  "name": "@css-bookends/css-bookends",
  "private": true,
  "version": "0.0.0",
  "description": "CSS-Bookends monorepo: typed, opt-in CSS helper books.",
  "license": "MIT",
  "author": "slafleche",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/css-bookends/css-bookends.git"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:browser": "playwright test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r run test:tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bash scripts/release-all.sh",
    "release:npm-only": "pnpm -r build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-multiline-arrays": "^4.1.8"
  }
}
